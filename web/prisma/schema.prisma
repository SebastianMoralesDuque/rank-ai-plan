generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model AiPlan {
  id             String   @id @default(cuid())
  toolName       String
  planName       String
  monthlyPrice   Float
  offers         String
  url            String?  @default("")
  lastUpdated    DateTime @default(now()) @updatedAt

  @@unique([toolName, planName])
}
